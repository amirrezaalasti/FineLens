# LLM (required for Graphiti ingestion & answers)
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini

# Graph database: embedded (no Docker), falkordb (Docker), or neo4j
# Use embedded if you have Redis on 6379 — FalkorDB Docker maps to 6380
GRAPH_BACKEND=embedded
FALKORDB_HOST=localhost
FALKORDB_PORT=6380
EMBEDDED_DB_PATH=data/graphiti.db

# Neo4j Aura (only if GRAPH_BACKEND=neo4j)
NEO4J_URI=neo4j+s://YOUR_INSTANCE.databases.neo4j.io
NEO4J_USER=YOUR_INSTANCE
NEO4J_PASSWORD=
NEO4J_DATABASE=YOUR_INSTANCE

# Open Legal Data (optional — read endpoints work without key)
OLDP_API_BASE=https://de.openlegaldata.io/api
OLDP_API_KEY=

# Federal legal API (recht.bund.de / NeuRIS testphase)
BUND_RECHT_API=https://testphase.rechtsinformationen.bund.de

# Auto-seed graph on backend startup (set true for first run)
AUTO_SEED_GRAPH=false

# Backend
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://127.0.0.1:3000,http://127.0.0.1:3002

# Disable Graphiti telemetry in dev
GRAPHITI_TELEMETRY_ENABLED=false
SEMAPHORE_LIMIT=5
